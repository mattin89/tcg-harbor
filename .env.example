# TCG Harbor fails closed when these values are blank; there is no shared demo
# account or production authentication bypass. Copy this file to the gitignored
# .env for local development and provide a browser-safe Supabase key.

# Browser-safe Supabase project configuration. New projects should use the
# publishable key; the legacy anon key remains supported as a fallback.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# Server-only Supabase access for one-time administrative scripts. Prefer the
# scoped secret-key format; the legacy service-role key is fallback-only.
# Never expose either value through a VITE_ variable or commit a populated file.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only authorized market-provider credentials. The provider classes expect
# an injected server transport; no live provider endpoint is included in this demo.
CARDMARKET_ACCESS_TOKEN=
CARDMARKET_APP_TOKEN=
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=
TCGPLAYER_BEARER_TOKEN=
