# TCG Harbor runs as a local browser demo without environment variables.
# Copy this file to the gitignored .env only when wiring optional adapters.

# Browser-safe Supabase project configuration (currently not consumed by src/).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only Supabase access. Never expose this value through a VITE_ variable.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only authorized market-provider credentials. The provider classes expect
# an injected server transport; no live provider endpoint is included in this demo.
CARDMARKET_ACCESS_TOKEN=
CARDMARKET_APP_TOKEN=
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=
TCGPLAYER_BEARER_TOKEN=
